# =========================================================================
# OCR-LLM RESEARCH - MASTER MLOPS GITIGNORE
# =========================================================================
# Mục tiêu: Đảm bảo bảo mật 100% dữ liệu hành chính (On-premise)
#          Ngăn chặn rò rỉ tài nguyên, rác VRAM và giới hạn GitHub.

# -------------------------------------------------------------------------
# 1. BẢO MẬT DỮ LIỆU & TÀI LIỆU (DATA SECURITY - CẤP ĐỘ 1)
# Tuyệt đối không đẩy bất kỳ dữ liệu thật nào của Quốc gia/Cơ quan lên Mạng.
# -------------------------------------------------------------------------
data/raw/*
data/interim/*
data/processed/*
data/raw_word_files/*
data/llm_training/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Thư mục chứa tài liệu Upload của người dùng qua giao diện Web
apps/backend/uploads/
apps/frontend/public/temp_uploads/
data/uploads/

# Runtime artifacts / local volumes
results/
debug_outputs/
artifacts/
cache/
.tmp/
tmp/
pgdata/
postgres_data/
redis-data/
redis_data/
chromadb/
data/chromadb/
data/cache/
data/tmp/
/vietidp.db
*.sqlite
*.sqlite3
data/*.db
data/**/*.db

# Các định dạng tài liệu nhạy cảm nếu vô tình để quên ở Root
/*.pdf
/*.docx
/*.doc
/*.png
/*.jpg
/*.jpeg
/*.tif
/*.tiff
# Ngoại trừ các ảnh phục vụ cho README.md
!docs/images/
!README.md
!*.md

# -------------------------------------------------------------------------
# 2. TRỌNG SỐ MÔ HÌNH & CHUYÊN GIA AI (MODEL WEIGHTS)
# GitHub giới hạn 100MB/file. Đẩy models lên sẽ gây lỗi sập Repository.
# -------------------------------------------------------------------------
models/base_models/*
models/finetuned/*
models/stamp_model/*
models/qwen_finetuned/*
!models/base_models/.gitkeep
!models/finetuned/.gitkeep
!models/stamp_model/.gitkeep

# Chặn mọi đuôi file Model khổng lồ
*.pt
*.pth
*.onnx
*.safetensors
*.bin
*.gguf
*.h5
*.pb
*.tflite
*.ckpt

# -------------------------------------------------------------------------
# 3. NHẬT KÝ HUẤN LUYỆN & THEO DÕI ĐO LƯỜNG (LOGS & METRICS)
# -------------------------------------------------------------------------
# Thư mục xuất hệ thống Unsloth/HuggingFace Trainer
outputs/
runs/
wandb/
.hydra/
mlruns/

# Logs Backend/Hệ thống
logs/
*.log
apps/backend/out.log
apps/backend/err.log

# -------------------------------------------------------------------------
# 4. THÔNG TIN CẤU HÌNH NHẠY CẢM (SECRETS & CONFIGS)
# -------------------------------------------------------------------------
.env
.env.*
!.env.example
credentials.json
client_secret.json
auth.json

# -------------------------------------------------------------------------
# 5. MÔI TRƯỜNG PYTHON CỤC BỘ (PYTHON ENVIRONMENT)
# -------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/

# -------------------------------------------------------------------------
# 6. MÔI TRƯỜNG THỰC THI JUPYTER (NOTEBOOKS)
# -------------------------------------------------------------------------
.ipynb_checkpoints
profile_default/
ipython_config.py

# -------------------------------------------------------------------------
# 7. MÔI TRƯỜNG REACT/NODEJS (FRONTEND/BACKEND)
# -------------------------------------------------------------------------
node_modules/
apps/frontend/node_modules/
apps/backend/node_modules/
dist/
build/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/

