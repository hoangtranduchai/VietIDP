# =========================================================================
# VietIDP — MASTER GITIGNORE
# =========================================================================
# Canonical stack: FastAPI + React/Vite + PostgreSQL + Ollama
# Mục tiêu: Bảo mật 100% dữ liệu hành chính (On-premise)
#           Ngăn rò rỉ tài nguyên, giới hạn GitHub 100MB/file.

# -------------------------------------------------------------------------
# 1. BẢO MẬT DỮ LIỆU & TÀI LIỆU (DATA SECURITY)
# Tuyệt đối không đẩy dữ liệu thật của Quốc gia/Cơ quan lên Mạng.
# -------------------------------------------------------------------------
data/raw/*
data/interim/*
data/processed/*
data/raw_word_files/*
data/llm_training/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Upload directories (user documents via web UI)
data/uploads/
apps/backend/uploads/
apps/frontend/public/temp_uploads/
backend/uploads/
uploads/

# Runtime artifacts / local volumes
results/
debug_outputs/
artifacts/
cache/
.tmp/
tmp/
pgdata/
postgres_data/
redis-data/
redis_data/
chromadb/
data/chromadb/
data/cache/
data/tmp/

# Database files
/vietidp.db
*.sqlite
*.sqlite3
data/*.db
data/**/*.db

# Sensitive document formats at root
/*.pdf
/*.docx
/*.doc
/*.png
/*.jpg
/*.jpeg
/*.tif
/*.tiff
# Exceptions for README assets
!docs/images/
!README.md
!*.md

# -------------------------------------------------------------------------
# 2. MODEL WEIGHTS (GitHub 100MB limit per file)
# -------------------------------------------------------------------------
models/base_models/*
models/finetuned/*
models/stamp_model/*
models/qwen_finetuned/*
!models/base_models/.gitkeep
!models/finetuned/.gitkeep
!models/stamp_model/.gitkeep

# Block all large model file types
*.pt
*.pth
*.onnx
*.safetensors
*.bin
*.gguf
*.h5
*.pb
*.tflite
*.ckpt

# -------------------------------------------------------------------------
# 3. TRAINING LOGS & METRICS
# -------------------------------------------------------------------------
outputs/
runs/
wandb/
.hydra/
mlruns/
unsloth_compiled_cache/

# System/Backend logs
logs/
*.log
apps/backend/out.log
apps/backend/err.log

# -------------------------------------------------------------------------
# 4. SECRETS & CONFIG
# -------------------------------------------------------------------------
.env
.env.*
!.env.example
credentials.json
client_secret.json
auth.json

# -------------------------------------------------------------------------
# 5. PYTHON ENVIRONMENT
# -------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
*.egg-info/
dist/

# -------------------------------------------------------------------------
# 6. JUPYTER NOTEBOOKS
# -------------------------------------------------------------------------
.ipynb_checkpoints
profile_default/
ipython_config.py

# -------------------------------------------------------------------------
# 7. NODE.JS / REACT / FRONTEND
# -------------------------------------------------------------------------
node_modules/
apps/frontend/node_modules/
apps/backend/node_modules/
dist/
build/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/

# -------------------------------------------------------------------------
# 8. OS & IDE
# -------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
[Tt]humbs.db
.vscode/
.idea/
*.swp
*.suo
*.user
*.pid

