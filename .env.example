# ═══════════════════════════════════════════════════════════════
# VietIDP Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy file này thành .env và sửa giá trị phù hợp.
# cp .env.example .env

# ── Ollama LLM ─────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MAX_CHARS=32000
OLLAMA_NUM_PREDICT=3000
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT=300

# ── OCR ────────────────────────────────────────────────────────
OCR_DPI=200
OCR_LANG=vi

# ── YOLO ───────────────────────────────────────────────────────
YOLO_CONF_THRESHOLD=0.5

# ── Security ───────────────────────────────────────────────────
# VIETIDP_REQUIRE_API_KEY=true se fail-closed neu thieu VIETIDP_API_KEY
# VIETIDP_CORS_ORIGINS nhan danh sach origins, cach nhau boi dau phay; mac dinh giu localhost cho dev.
VIETIDP_ENV=development
VIETIDP_REQUIRE_API_KEY=false
VIETIDP_API_KEY=
VIETIDP_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5174

# ── Frontend (Vite browser env) ────────────────────────────────
# VITE_API_KEY se duoc bundle vao client; chi dung cho local/dev convenience,
# khong phai production secret boundary. Production nen bao ve API bang server-side secret/edge proxy.
VITE_API_URL=http://localhost:8000
VITE_API_KEY=

# ── Server ─────────────────────────────────────────────────────
PORT=8000
