# ═══════════════════════════════════════════════════════════════
# VietIDP Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy file này thành .env và sửa giá trị phù hợp.
# cp .env.example .env

# ── Ollama LLM ─────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MAX_CHARS=32000
OLLAMA_NUM_PREDICT=3000
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT=300

# ── OCR ────────────────────────────────────────────────────────
OCR_DPI=200
OCR_LANG=vi

# ── YOLO ───────────────────────────────────────────────────────
YOLO_CONF_THRESHOLD=0.5

# ── Security ───────────────────────────────────────────────────
# Để trống = không yêu cầu API key
VIETIDP_API_KEY=

# ── Server ─────────────────────────────────────────────────────
PORT=5000
